# Floor Monitor Server Configuration

[server]
host = "0.0.0.0"
port = 3456

# VLM (Vision Language Model) inference backend
# Must be an OpenAI-compatible /v1/chat/completions endpoint.
# Works with: vLLM, Ollama (--openai flag), OpenAI, any compatible provider.
[vlm]

# --- Option 1: vLLM with Qwen (local) ---
# vllm serve Qwen/Qwen2.5-VL-3B-Instruct
api_url = "http://localhost:8000/v1/chat/completions"
model = "Qwen/Qwen2.5-VL-3B-Instruct"

# --- Option 2: Ollama (use its OpenAI-compatible endpoint) ---
# ollama serve
# api_url = "http://localhost:11434/v1/chat/completions"
# model = "qwen2.5-vl:3b"

# --- Option 3: OpenAI cloud ---
# api_url = "https://api.openai.com/v1/chat/completions"
# api_key = "sk-..."
# model = "gpt-4o-mini"

max_tokens = 200
# temperature = 0.1  # optional; omit to use provider default

# Optional: Telegram bot for alerts and Q&A
# The bot sends alerts, summaries, and replies to all listed chat IDs,
# and only accepts incoming messages from those chats.
# You can use either chat_id (single) or chat_ids (multiple), or both.
[telegram]
# bot_token = "123456:ABC-DEF..."
# chat_id = "12345678"               # single chat
# chat_ids = ["12345678", "87654321"] # multiple chats

# Optional: ASR (speech-to-text) for Telegram voice messages
# Requires ffmpeg installed for OGG-to-WAV conversion.
# Must be an OpenAI-compatible /v1/audio/transcriptions endpoint.
# [asr]
# api_url = "https://api.openai.com/v1/audio/transcriptions"
# api_key = "sk-..."
# model = "whisper-1"

# Optional: LLM for intent classification of Telegram messages
# Routes natural language (text or transcribed voice) to the right handler:
# visual question, PTZ control, patrol, snapshot, history summary.
# Without this, the bot uses simple keyword matching.
# Must be an OpenAI-compatible /v1/chat/completions endpoint.
# [llm]
# api_url = "http://localhost:8000/v1/chat/completions"
# api_key = "sk-..."
# model = "Qwen/Qwen2.5-3B-Instruct"
# max_tokens = 150
# temperature = 0.0  # optional; omit to use provider default

# Monitor mode — controls VLM prompts and alert behavior.
# Profiles are loaded from the profiles/ directory (editable TOML files).
# To create a custom profile, copy an existing .toml and edit it.
[monitor]
# Built-in profiles:
#   "kid"      — children's room safety (roughhousing, climbing, sharp objects, ...)
#   "office"   — workplace safety (injury, conflict, fire, intruders, ...)
#   "retail"   — store operations (unattended customers, cleanliness, ...)
#   "security" — home security (intruder, forced entry, fire, ...)
default_profile = "kid"
summary_window_min = 30    # periodic summary pushed to Telegram (minutes, 0 to disable)
alert_consecutive = 2      # consecutive high-risk frames before firing an alert
alert_cooldown_sec = 120   # seconds between alerts for the same camera
